<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ProyectoComanda" parent="Theme.Material3.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.ProyectoComanda" parent="Base.Theme.ProyectoComanda" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_main</item>

        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_icon</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/secondary_orange</item>

        <item name="postSplashScreenTheme">@style/Theme.ProyectoComanda</item>
    </style>

    <style name="Theme.App.PopupMenu" parent="ThemeOverlay.Material3.Dark">
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:fontFamily">@font/lexend_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="colorControlHighlight">@color/orange_indicator</item>
    </style>

    <style name="App.Custom.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/orange_indicator</item>
    </style>

    <style name="App.BottomNav.TextAppearance" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:fontFamily">@font/lexend_medium</item>
        <item name="fontFamily">@font/lexend_medium</item>
    </style>

    <style name="Widget.App.IconButton" parent="Widget.Material3.Button.Icon">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:padding">0dp</item>

        <item name="iconGravity">textStart</item>
        <item name="iconPadding">0dp</item>

        <item name="rippleColor">@color/orange_indicator</item>
    </style>
</resources>