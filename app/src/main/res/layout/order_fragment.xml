<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    tools:context=".OrderFragment">

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:fontFamily="@font/lexend_medium"
        android:text="@string/order_resumeText"
        android:textColor="@color/text_light"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TableLayout
        android:id="@+id/tableOrder"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView">

        <TableRow
            android:id="@+id/tableOrder_title"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:backgroundTint="@color/bg_table_title">

            <TextView
                android:layout_column="1"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/lexend_medium"
                android:text="@string/order_table_titleItemText"
                android:textColor="@color/text_light"
                android:textSize="14sp" />

            <TextView
                android:layout_column="2"
                android:fontFamily="@font/lexend_medium"
                android:text="@string/order_table_titleAmountText"
                android:textColor="@color/text_light"
                android:textSize="14sp" />

            <TextView
                android:fontFamily="@font/lexend_medium"
                android:text="@string/order_table_titlePriceText"
                android:textColor="@color/text_light"
                android:textSize="14sp" />

            <TextView
                android:fontFamily="@font/lexend_medium"
                android:gravity="right"
                android:text="@string/order_table_titleTotalText"
                android:textColor="@color/text_light"
                android:textSize="14sp" />
        </TableRow>

    </TableLayout>
</androidx.constraintlayout.widget.ConstraintLayout>